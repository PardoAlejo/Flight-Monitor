# ===========================================
# CONFIGURACIÓN DE FLIGHT MONITOR
# ===========================================
# Copia este archivo a .env y completa con tus datos:
#   cp .env.example .env
#
# IMPORTANTE: Nunca subas el archivo .env a GitHub
# ===========================================

# SerpApi (REQUERIDO)
# Obtén tu API key en: https://serpapi.com
SERPAPI_KEY=tu_serpapi_api_key_aqui

# Email - Gmail SMTP (OPCIONAL)
# Necesitas crear una "App Password" en tu cuenta de Google:
# https://myaccount.google.com/apppasswords
EMAIL_SENDER=tu_email@gmail.com
EMAIL_PASSWORD=tu_app_password_de_16_caracteres
EMAIL_RECEIVER=email_destino@gmail.com

# Telegram Bot (OPCIONAL)
# Crea un bot con @BotFather y obtén tu chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Base de datos (default: flight_prices.db)
DB_PATH=flight_prices.db

# Intervalo de chequeo en minutos (solo para modo continuo)
CHECK_INTERVAL_MINUTES=60
